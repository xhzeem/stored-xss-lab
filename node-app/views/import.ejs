<%- include('partials/header') %>

<h1>Content Import</h1>
<p>Import CSV data into your CMS. View imported rows below.</p>

<div class="card">
  <h2>Import Data</h2>
  <form method="POST" action="<%= prefix %>/import" class="form">
    <div class="form-group">
      <label for="filename">Source Filename</label>
      <input type="text" id="filename" name="filename" placeholder="data.csv" required>
    </div>
    <div class="form-group">
      <label for="row_data">Row Data (comma-separated)</label>
      <textarea id="row_data" name="row_data" rows="3" placeholder="value1,value2,value3" required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Import Row</button>
  </form>
</div>

<div class="card">
  <h2>Imported Data</h2>
  <% if (imports.length === 0) { %>
    <p>No imports yet.</p>
  <% } else { %>
    <% imports.forEach(imp => { %>
      <div class="import-item">
        <strong>File:</strong> <%= imp.filename %>
        <strong>Imported:</strong> <%= imp.imported_at %>
        <!-- XSS-NODE-08: row_data unescaped -->
        <div class="import-data">
          <%- imp.row_data %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include('partials/footer') %>
